{
  "_comment": "Shared behavioral contract for the Whisper hallucination filter. Consumed by backend/tests/test_utils.py (Python) and Tests/VoxFlowAppTests/HallucinationFilterTests.swift (Swift). Every case must produce `expected` in BOTH implementations. short_audio means source clip < 3s.",
  "cases": [
    { "text": "Hello.", "short_audio": true, "expected": true, "note": "classic ghost greeting, short" },
    { "text": "hello", "short_audio": false, "expected": true, "note": "lone greeting filtered at any duration" },
    { "text": "Hi!", "short_audio": false, "expected": true, "note": "punctuation-insensitive" },
    { "text": "Hey", "short_audio": true, "expected": true, "note": "greeting" },
    { "text": "hello hello hello", "short_audio": true, "expected": true, "note": "identical repeats on short audio" },
    { "text": "hello hello hello", "short_audio": false, "expected": false, "note": "repeats can be real emphasis in long dictation" },
    { "text": "Hello everyone", "short_audio": false, "expected": true, "note": "greeting pair, any duration" },
    { "text": "hi guys", "short_audio": false, "expected": true, "note": "greeting pair" },
    { "text": "hey there", "short_audio": false, "expected": true, "note": "greeting pair" },
    { "text": "yeah", "short_audio": true, "expected": true, "note": "short-only filler word" },
    { "text": "yeah", "short_audio": false, "expected": false, "note": "could end a real long dictation" },
    { "text": "okay", "short_audio": true, "expected": true, "note": "short-only filler word" },
    { "text": "ok", "short_audio": true, "expected": true, "note": "short-only filler word" },
    { "text": "you", "short_audio": true, "expected": true, "note": "classic Whisper silence token" },
    { "text": "you", "short_audio": false, "expected": false, "note": "long audio: keep" },
    { "text": "Thanks.", "short_audio": true, "expected": true, "note": "short-only" },
    { "text": "Thanks.", "short_audio": false, "expected": false, "note": "long audio: keep" },
    { "text": "thank you", "short_audio": true, "expected": true, "note": "short-only pair" },
    { "text": "thank you", "short_audio": false, "expected": false, "note": "long audio: keep" },
    { "text": "thank you so much", "short_audio": true, "expected": true, "note": "exact phrase, short-only" },
    { "text": "thank you so much", "short_audio": false, "expected": false, "note": "real gratitude in long dictation" },
    { "text": "Thank you for watching.", "short_audio": false, "expected": true, "note": "YouTube outro, any duration" },
    { "text": "Thanks for watching!", "short_audio": false, "expected": true, "note": "YouTube outro" },
    { "text": "Thank you so much for watching.", "short_audio": false, "expected": true, "note": "YouTube outro" },
    { "text": "Thank you for watching everybody", "short_audio": false, "expected": true, "note": "outro with trailing token still filtered" },
    { "text": "Thank you for the coffee", "short_audio": true, "expected": false, "note": "F3 guard: thank-you family needs watching/listening" },
    { "text": "Thank you so much for your help today", "short_audio": false, "expected": false, "note": "F3 guard: real gratitude sentence" },
    { "text": "Please subscribe.", "short_audio": false, "expected": true, "note": "YouTube outro" },
    { "text": "Like and subscribe.", "short_audio": false, "expected": true, "note": "YouTube outro" },
    { "text": "Please like and subscribe.", "short_audio": false, "expected": true, "note": "YouTube outro, please-prefixed" },
    { "text": "Subscribe to my channel.", "short_audio": false, "expected": true, "note": "YouTube outro" },
    { "text": "See you next time.", "short_audio": false, "expected": true, "note": "outro family" },
    { "text": "I'll see you in the next one.", "short_audio": false, "expected": true, "note": "outro family, contraction" },
    { "text": "subscribe me to the newsletter", "short_audio": false, "expected": false, "note": "F3 guard: real imperative" },
    { "text": "♪♪", "short_audio": false, "expected": true, "note": "music notes" },
    { "text": "...", "short_audio": false, "expected": true, "note": "ellipsis-only" },
    { "text": "…", "short_audio": true, "expected": true, "note": "unicode ellipsis" },
    { "text": "[typing sounds]", "short_audio": false, "expected": true, "note": "bracketed noise cue" },
    { "text": "(keyboard clacking)", "short_audio": true, "expected": true, "note": "parenthesized noise cue" },
    { "text": "Hello world", "short_audio": false, "expected": false, "note": "F-guard: greeting + non-target word" },
    { "text": "Hello world", "short_audio": true, "expected": false, "note": "F-guard: greeting + non-target word, short" },
    { "text": "Hello, how are you?", "short_audio": false, "expected": false, "note": "real greeting sentence" },
    { "text": "Approved", "short_audio": true, "expected": false, "note": "F1 guard: lone real word" },
    { "text": "Cancel", "short_audio": true, "expected": false, "note": "F1 guard: lone real word" },
    { "text": "Seven", "short_audio": true, "expected": false, "note": "F1 guard: lone number word" },
    { "text": "no no no", "short_audio": false, "expected": false, "note": "F5 guard: emphasis on long audio" },
    { "text": "no no no", "short_audio": true, "expected": true, "note": "identical repeats on short audio" },
    { "text": "I'm watching the kids", "short_audio": true, "expected": false, "note": "F3 guard: watching in real speech" },
    { "text": "change the channel", "short_audio": true, "expected": false, "note": "F3 guard: channel in real speech" },
    { "text": "send it", "short_audio": true, "expected": false, "note": "real two-word command" },
    { "text": "Looks good to me", "short_audio": false, "expected": false, "note": "real phrase" }
  ]
}
